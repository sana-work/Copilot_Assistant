{
  "name": "@copilot-architect/vscode-extension",
  "displayName": "Copilot Architect",
  "description": "Thin VS Code shell for Copilot Architect CLI and MCP workflows.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publisher": "internal",
  "categories": [
    "Other"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:copilot-architect.architect",
    "onView:copilotArchitect.dashboard",
    "onCommand:copilotArchitect.openDashboard",
    "onCommand:copilotArchitect.refreshDashboard",
    "onCommand:copilotArchitect.analyzeRepo",
    "onCommand:copilotArchitect.buildIndex",
    "onCommand:copilotArchitect.generatePlan",
    "onCommand:copilotArchitect.validate",
    "onCommand:copilotArchitect.review",
    "onCommand:copilotArchitect.startMcp",
    "onCommand:copilotArchitect.installAgents",
    "onCommand:copilotArchitect.generateInstructions",
    "onCommand:copilotArchitect.openRepoInNewWindow",
    "onCommand:copilotArchitect.workspaceScan",
    "onCommand:copilotArchitect.setupMcp"
  ],
  "contributes": {
    "commands": [
      {
        "command": "copilotArchitect.openDashboard",
        "title": "Copilot Architect: Open Dashboard"
      },
      {
        "command": "copilotArchitect.refreshDashboard",
        "title": "Copilot Architect: Refresh Dashboard",
        "icon": "$(refresh)"
      },
      {
        "command": "copilotArchitect.analyzeRepo",
        "title": "Copilot Architect: Analyze Repo",
        "icon": "$(repo)"
      },
      {
        "command": "copilotArchitect.buildIndex",
        "title": "Copilot Architect: Build Index",
        "icon": "$(database)"
      },
      {
        "command": "copilotArchitect.generatePlan",
        "title": "Copilot Architect: Generate Plan",
        "icon": "$(list-tree)"
      },
      {
        "command": "copilotArchitect.validate",
        "title": "Copilot Architect: Validate",
        "icon": "$(pass)"
      },
      {
        "command": "copilotArchitect.review",
        "title": "Copilot Architect: Review",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "copilotArchitect.startMcp",
        "title": "Copilot Architect: Start MCP",
        "icon": "$(server-process)"
      },
      {
        "command": "copilotArchitect.installAgents",
        "title": "Copilot Architect: Install Agents",
        "icon": "$(hubot)"
      },
      {
        "command": "copilotArchitect.generateInstructions",
        "title": "Copilot Architect: Generate Instructions",
        "icon": "$(book)"
      },
      {
        "command": "copilotArchitect.openRepoInNewWindow",
        "title": "Copilot Architect: Open Repo in New Window",
        "icon": "$(folder-opened)"
      },
      {
        "command": "copilotArchitect.workspaceScan",
        "title": "Copilot Architect: Scan and Register Sub-repos",
        "icon": "$(source-control)"
      },
      {
        "command": "copilotArchitect.setupMcp",
        "title": "Copilot Architect: Setup MCP Server",
        "icon": "$(plug)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilotArchitect",
          "title": "Copilot Architect",
          "icon": "resources/copilot-architect.svg"
        }
      ]
    },
    "views": {
      "copilotArchitect": [
        {
          "id": "copilotArchitect.dashboard",
          "name": "Copilot Architect",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "copilotArchitect.refreshDashboard",
          "when": "view == copilotArchitect.dashboard",
          "group": "navigation"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "copilot-architect.architect",
        "fullName": "Copilot Architect",
        "name": "architect",
        "description": "Analyze repos, generate plans, validate, and review with Copilot Architect",
        "isSticky": false,
        "commands": [
          {
            "name": "analyze",
            "description": "Detect languages, frameworks, and entry points in the current repo"
          },
          {
            "name": "index",
            "description": "Build a searchable local file index"
          },
          {
            "name": "plan",
            "description": "Generate a feature implementation plan — follow with your feature description"
          },
          {
            "name": "validate",
            "description": "Run build, test, lint, and format commands"
          },
          {
            "name": "review",
            "description": "Generate a review report from the latest git diff"
          },
          {
            "name": "search",
            "description": "Search the repo index — follow with your search query"
          },
          {
            "name": "diagnostics",
            "description": "Report repo readiness and analysis signals"
          },
          {
            "name": "agents",
            "description": "Install custom Copilot agent templates into .github/agents/"
          },
          {
            "name": "instructions",
            "description": "Generate .github/copilot-instructions.md from repo analysis"
          },
          {
            "name": "help",
            "description": "Show all available Copilot Architect commands"
          }
        ]
      }
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  }
}
