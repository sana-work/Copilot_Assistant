{
  "name": "copilot-architect",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript/Node.js-first internal tool for repo-aware coding agent workflows.",
  "engines": {
    "node": ">=20.11"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "cli": "node packages/cli/dist/index.js",
    "package:local": "node scripts/package-local.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.9"
  }
}
